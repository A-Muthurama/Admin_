generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum OfferStatus {
  PENDING
  APPROVED
  REJECTED
}

model Offer {
  id          String @id @default(uuid())
  externalOfferId Int?    @unique
  title       String
  description String
  price       Float

  storeLat Float
  storeLng Float

  status   OfferStatus @default(PENDING)
  isActive Boolean     @default(false)

  createdAt DateTime @default(now())

  vendorId String
  vendor   VendorProfile @relation("VendorProfileToOffer", fields: [vendorId], references: [id])
  images OfferImage[]
}

model OfferImage {
  id        String      @id @default(uuid())
  url       String
  publicId  String
  status    MediaStatus @default(PENDING)
  createdAt DateTime    @default(now())

  offerId String
  offer   Offer @relation(fields: [offerId], references: [id])
}



model User {
  id            String         @id @default(uuid())
  email         String         @unique
  password      String
  role          Role
  createdAt     DateTime       @default(now())
  vendorProfile VendorProfile?
  adminPasswordResetOtps AdminPasswordResetOtp[]
}

model AdminPasswordResetOtp {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  otpHash   String
  expiresAt DateTime
  usedAt    DateTime?
  attempts  Int      @default(0)
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

model VendorProfile {
  id        String   @id @default(uuid())
  externalVendorId Int?    @unique
  userId    String   @unique
  shopName  String
  ownerName String
  kycDocs   String
  status    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
  offers    Offer[]  @relation("VendorProfileToOffer")
}

enum Role {
  ADMIN
  VENDOR_PENDING
  VENDOR_APPROVED
}

enum MediaStatus {
  PENDING
  APPROVED
  REJECTED
}

